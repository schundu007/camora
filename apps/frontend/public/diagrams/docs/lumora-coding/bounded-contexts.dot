// Lumora Coding — Bounded Contexts
// Render: dot -Tpng -Gdpi=150 bounded-contexts.dot -o bounded-contexts.png
digraph LumoraCodingBoundedContexts {
  graph [
    bgcolor="white",
    rankdir="LR",
    splines="spline",
    nodesep=0.5,
    ranksep=0.95,
    pad=0.3,
    fontname="Inter, Helvetica, Arial, sans-serif"
  ];
  node [
    shape=box,
    style="rounded,filled",
    fontname="Inter, Helvetica, Arial, sans-serif",
    fontsize=11,
    fontcolor="#0F172A",
    margin="0.24,0.14",
    penwidth=1.3
  ];
  edge [
    fontname="Inter, Helvetica, Arial, sans-serif",
    fontsize=9.5,
    color="#64748B",
    fontcolor="#475569",
    penwidth=1.1,
    arrowsize=0.7,
    style=dashed
  ];

  problem_input [
    label="Problem Input\nPaste / URL fetch /\nimage OCR",
    fillcolor="#DBEAFE", color="#0047AB", fontcolor="#0047AB"
  ];
  language [
    label="Language\nLANGUAGES catalog,\nMonaco wiring, translate",
    fillcolor="#F5F3FF", color="#6D28D9", fontcolor="#5B21B6"
  ];
  solver [
    label="Solver\nbuildCodingSystemPrompt,\n3-pass reliability,\nextractJsonFromText",
    fillcolor="#DCFCE7", color="#15803D", fontcolor="#166534"
  ];
  presentation [
    label="Presentation\n3 cards, complexity badges,\nMonaco code, trace steps",
    fillcolor="#FFEDD5", color="#9A3412", fontcolor="#9A3412"
  ];
  metering [
    label="Metering\ncoding_usage,\ndaily limits,\nai_hours_usage",
    fillcolor="#FEF3C7", color="#C9A227", fontcolor="#7C5E00"
  ];

  problem_input -> solver [label="ProblemSubmitted\n{ problem, language }"];
  language -> solver [label="LanguageSelected\n{ id, monacoId }"];
  solver -> presentation [label="SolutionsGenerated\n{ json, recovery_pass }"];
  language -> presentation [label="TranslationRequested\n→ /translate"];
  solver -> metering [label="SolveCompleted\n{ tokens_in, tokens_out,\nlatency_ms }"];
  metering -> solver [label="DailyLimitExceeded → 429",
                      color="#C9A227", fontcolor="#7C5E00"];

  { rank=same; problem_input; language; }
  { rank=same; solver; }
  { rank=same; presentation; metering; }
}
