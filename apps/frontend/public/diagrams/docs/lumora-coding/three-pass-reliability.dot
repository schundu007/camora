// Lumora Coding — 3-Pass Reliability State Machine
// Render: dot -Tpng -Gdpi=150 three-pass-reliability.dot -o three-pass-reliability.png
digraph LumoraCoding3Pass {
  graph [
    bgcolor="white",
    rankdir="TB",
    splines="spline",
    nodesep=0.5,
    ranksep=0.65,
    pad=0.3,
    fontname="Inter, Helvetica, Arial, sans-serif"
  ];
  node [
    shape=box,
    style="rounded,filled",
    fontname="Inter, Helvetica, Arial, sans-serif",
    fontsize=11,
    fontcolor="#0F172A",
    margin="0.22,0.14",
    penwidth=1.3
  ];
  edge [
    fontname="Inter, Helvetica, Arial, sans-serif",
    fontsize=10,
    color="#64748B",
    fontcolor="#475569",
    penwidth=1.2,
    arrowsize=0.7
  ];

  start [
    label="solve request",
    shape=ellipse,
    fillcolor="#DBEAFE", color="#0047AB", fontcolor="#0047AB"
  ];

  // Pass 1
  pass1 [
    label="Pass 1 — Streaming\nclient.messages.stream()\ntier model\n(Sonnet paid / Haiku free)",
    fillcolor="#DCFCE7", color="#15803D", fontcolor="#166534"
  ];
  pass1_retry [
    label="Transport retry\n529/503/502/504/429\n2 attempts, 500ms / 1500ms",
    shape=note,
    fillcolor="#FFFFFF", color="#15803D", fontcolor="#15803D"
  ];

  // Pass 2
  pass2 [
    label="Pass 2 — Strict reminder\nNon-streaming\nsame model\n+ STRICT_JSON_REMINDER",
    fillcolor="#FFEDD5", color="#9A3412", fontcolor="#9A3412"
  ];

  // Pass 3
  pass3 [
    label="Pass 3 — Fallback model\nNon-streaming\nfallbackModelFor(model)\nSonnet ↔ Haiku",
    fillcolor="#F5F3FF", color="#6D28D9", fontcolor="#5B21B6"
  ];

  // Outcomes
  ok [
    label="answer event\n{ parsed: { json, format: 'ascend_json' },\n  recovery_pass, model_used, latency_ms }",
    fillcolor="#FEF3C7", color="#C9A227", fontcolor="#7C5E00"
  ];
  fail [
    label="error event\n{ msg, retryable, parse_failure, category }",
    fillcolor="#FEE2E2", color="#B91C1C", fontcolor="#991B1B"
  ];

  start -> pass1;
  pass1 -> pass1_retry [style=dashed, arrowhead=none, label="on transient 5xx/429"];
  pass1_retry -> pass1 [style=dashed, label="≤ 2 retries"];
  pass1 -> ok [label="JSON parsed"];
  pass1 -> pass2 [label="parse failure or\nretries exhausted"];

  pass2 -> ok [label="JSON parsed"];
  pass2 -> pass3 [label="still invalid"];

  pass3 -> ok [label="JSON parsed"];
  pass3 -> fail [label="all 3 passes failed"];

  // Layout hints
  { rank=same; pass1; pass1_retry; }
}
