{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "apps/lumora-backend/**",
      "packages/**",
      "pnpm-workspace.yaml",
      "pnpm-lock.yaml",
      "package.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter lumora-backend start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
