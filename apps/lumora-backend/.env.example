# Server
PORT=8000
NODE_ENV=production

# Database (shared with Ascend)
DATABASE_URL=postgresql://user:pass@host:5432/camora

# JWT (MUST match Ascend backend)
JWT_SECRET=your-shared-jwt-secret

# AI
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
CLAUDE_MODEL=claude-haiku-4-5-20251001
MAX_TOKENS_QUICK=2000
MAX_TOKENS_DESIGN=8192

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_LIFETIME=price_xxx

# AI Services (Python microservice)
AI_SERVICES_URL=http://localhost:8001

# Redis (optional, for rate limiting)
REDIS_URL=redis://localhost:6379

# Quota
DAILY_FREE_LIMIT=10
