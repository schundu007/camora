# Server
PORT=3009
NODE_ENV=production

# Database (shared with Lumora)
DATABASE_URL=postgresql://user:pass@host:5432/camora

# JWT (MUST match Lumora backend)
JWT_SECRET_KEY=your-shared-jwt-secret

# Google OAuth
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URI=https://camora.cariara.com/api/auth/google/callback

# AI
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_QUARTERLY_PRO=price_xxx
STRIPE_PRICE_DESKTOP=price_xxx
STRIPE_PRICE_ADDON=price_xxx

# Redis
REDIS_URL=redis://localhost:6379

# Frontend URL (for OAuth redirects)
FRONTEND_URL=https://camora.cariara.com

# Admin
ADMIN_SECRET=your-admin-secret
